{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "generate:ascii": "node scripts/generate-logokabinet-ascii.mjs",
        "build": "npm run generate:ascii && vite build && vite build --ssr",
        "dev": "vite",
        "lint": "eslint resources/js resources/svelte vite.config.js && prettier --check resources/css/app.css resources/js resources/svelte vite.config.js eslint.config.js tailwind.config.js",
        "lint:fix": "eslint resources/js resources/svelte vite.config.js --fix && prettier --write resources/css/app.css resources/js resources/svelte vite.config.js eslint.config.js tailwind.config.js",
        "postinstall": "node -e \"const fs=require('fs'); fs.cpSync('node_modules/tinymce','public/tinymce',{recursive:true,force:true})\""
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@internationalized/date": "^3.12.0",
        "@lucide/svelte": "^1.8.0",
        "@sveltejs/enhanced-img": "^0.10.4",
        "@sveltejs/vite-plugin-svelte": "^6.2.1",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "bits-ui": "^2.17.3",
        "concurrently": "^9.0.1",
        "eslint": "^10.3.0",
        "eslint-plugin-svelte": "^3.17.1",
        "globals": "^17.6.0",
        "laravel-vite-plugin": "^2.0.0",
        "mode-watcher": "^1.1.0",
        "playwright": "^1.59.1",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "svelte": "^5.28.2",
        "svelte-sonner": "^1.1.0",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@humanspeak/svelte-motion": "^0.2.0",
        "@inertiajs/svelte": "^3.0.3",
        "@tinymce/tinymce-svelte": "^4.0.1",
        "image-to-ascii": "^3.3.0",
        "laravel-echo": "^2.2.4",
        "lighthouse": "^13.1.0",
        "lucide-svelte": "^1.0.1",
        "motion": "^12.38.0",
        "posthog-js": "^1.369.2",
        "pusher-js": "^8.4.0-rc2",
        "textmode.js": "^0.12.0",
        "tinymce": "^8.5.0"
    }
}
