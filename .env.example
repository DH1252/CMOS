APP_NAME="CMOS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
SERVICE_ROLE=all

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cmos
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=database
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

APP_SERVER_HOST=127.0.0.1
APP_SERVER_PORT=8000

QUEUE_WORKER_QUEUE=default
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_TIMEOUT=90
QUEUE_WORKER_SLEEP=3
QUEUE_WORKER_MEMORY=256

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=cmos-reverb-app
REVERB_APP_KEY=cmos-reverb-key
REVERB_APP_SECRET=cmos-reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8081
REVERB_DEBUG=false
REVERB_LOG_FILE=
REVERB_LOG_LEVEL=debug
REVERB_LOG_DAILY_DAYS=7

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://app.posthog.com
POSTHOG_DISABLED=true

VITE_POSTHOG_KEY="${POSTHOG_PROJECT_TOKEN}"
VITE_POSTHOG_HOST="${POSTHOG_HOST}"
VITE_POSTHOG_DISABLED="${POSTHOG_DISABLED}"
